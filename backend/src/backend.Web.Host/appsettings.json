{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=MzansiLegalDb;Username=postgres;Password=YOUR_LOCAL_PASSWORD"
  },
  "App": {
    "ServerRootAddress": "https://localhost:44311/",
    "ClientRootAddress": "http://localhost:4200/",
    "CorsOrigins": "http://localhost:4200,http://localhost:8080,http://localhost:8081,http://localhost:3000"
  },
  "Authentication": {
    "JwtBearer": {
      "IsEnabled": "true",
      "SecurityKey": "YOUR_JWT_SECURITY_KEY_MIN_16_CHARS",
      "Issuer": "backend",
